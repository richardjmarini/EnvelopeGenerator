	(text "TODO:\nAdd Rail Clamps to limit output to supply voltages\nAdd rail Clamps to limit input signal to supply voltages\nAdd resister to input signal for protection\nSwap R3 w/ POT to control decay\nSwap R0 w/ POT to control attack\nAdopt Trigger input to be Gate input\nUse Gate falling edge to control when release starts\nUse comparator w/ POT to control threshold to determine sustain level\nKeep in mind the need for a diode switching circuit\n\n"
		(exclude_from_sim no)
		(at 203.2 47.244 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "27d5050e-9aab-4408-9bed-504efd0fa619")
	)
	(text ".options method=gear \n.options gmin=1e-9 cshunt=1e-12 \n.options reltol=1e-2 abstol=1e-9 vntol=1e-6 \n.options itl1=300 itl4=300 \n.options maxstep=100p\n.options temp=60\n.tran 10u 10us\n.control\nrun\nplot v(Gate) v(Output) V(Net-_D1-K_) V(Net-_D1-A_) v(Net-_D6-A_)\nplot i(R0) i(R1) i(R2) i(R3) i(C2) i(C8) i(D1) i(D6)\n.endc\n"
		(exclude_from_sim no)
		(at 54.356 123.19 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "b517c6b6-563f-4523-b40b-d547f832b325")
